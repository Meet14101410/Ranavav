<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Ranavav Profile - Porbandar</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: #eef2f3; display: flex; justify-content: center; padding: 20px; }
        .card { background: #fff; width: 480px; border-radius: 15px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); overflow: hidden; }
        .banner { background: #2c3e50; color: #ecf0f1; padding: 25px; text-align: center; }
        .content { padding: 30px; }
        .stat-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
        .label { font-weight: bold; color: #34495e; }
        .value { color: #16a085; font-weight: 600; }
    </style>
</head>
<body>
    <div class="card">
        <div class="banner"><h1>📍 Ranavav</h1><p>Taluka Headquarters, Porbandar</p></div>
        <div class="content">
            <div class="stat-row"><span class="label">District:</span><span class="value">Porbandar</span></div>
            <div class="stat-row"><span class="label">Historical Site:</span><span class="value">Jambuvant's Cave</span></div>
            <div class="stat-row"><span class="label">Main Industry:</span><span class="value">Cement & Mining</span></div>
            <div class="stat-row"><span class="label">Pincode:</span><span class="value">360550</span></div>
        </div>
    </div>
</body>
</html>
